<%# Day-of-month => distance %>
<% daily = @digest.monthly_distances.to_h %>
<%# Weekday totals, Mon..Sun %>
<% weekday_totals = Array.new(7, 0.0) %>
<% daily.each do |day_str, distance|
     begin
       wday = Date.new(@digest.year, @digest.month, day_str.to_i).wday
       weekday_totals[wday] += distance.to_f
     rescue ArgumentError
       next
     end
   end %>
<% weekday_totals = weekday_totals[1..6] + [weekday_totals[0]] %>
<% active_days = daily.values.count { |d| d.to_f.positive? } %>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
           max-width: 600px; margin: 0 auto; padding: 20px;
           color: #1a1a1a; background: #fafafa; }
    pre.ascii { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
                line-height: 1.25; font-size: 13px; white-space: pre;
                background: #fff; padding: 16px; border-radius: 6px;
                border: 1px solid #e5e5e5; overflow-x: auto; }
    h1, h2 { color: #1a1a1a; }
    .meta { color: #666; font-size: 14px; }
    .footer { color: #888; font-size: 12px; margin-top: 32px;
              border-top: 1px solid #e5e5e5; padding-top: 16px; }
  </style>
</head>
<body>
  <h1>Your <%= Date::MONTHNAMES[@digest.month] %> <%= @digest.year %> in review</h1>
  <p class="meta">Here's what your location history looked like last month.</p>

  <h2>OVERVIEW</h2>
  <pre class="ascii">
Distance       <%= @digest.distance %> <%= @distance_unit %>
Active days    <%= active_days %>
Countries      <%= @digest.time_spent_by_location.to_h['countries'].to_a.size %>
Cities         <%= @digest.time_spent_by_location.to_h['cities'].to_a.size %>
</pre>

  <h2>WEEKLY PATTERN</h2>
  <pre class="ascii"><%= ascii_hbar(
      weekday_totals,
      labels: %w[Mon Tue Wed Thu Fri Sat Sun],
      width: 20,
      suffix: " #{@distance_unit}"
    ) %></pre>

  <h2>DAILY DISTANCE</h2>
  <pre class="ascii"><%= ascii_sparkline(
      (1..31).map { |d| @digest.monthly_distances.to_h[d.to_s].to_f }
             .reject(&:zero?)
             .presence || [0]
    ) %></pre>

  <% top_countries = @digest.time_spent_by_location.to_h['countries'].to_a %>
  <% if top_countries.any? %>
    <h2>TOP COUNTRIES</h2>
    <pre class="ascii"><%= ascii_ranked_list(top_countries, value_key: 'minutes', label_key: 'name', width: 20, format: ->(m) { "#{(m.to_f / 60).round}h" }) %></pre>
  <% end %>

  <% top_cities = @digest.time_spent_by_location.to_h['cities'].to_a %>
  <% if top_cities.any? %>
    <h2>TOP CITIES</h2>
    <pre class="ascii"><%= ascii_ranked_list(top_cities.first(5), value_key: 'minutes', label_key: 'name', width: 20, format: ->(m) { "#{(m.to_f / 60).round}h" }) %></pre>
  <% end %>

  <% first_countries = @digest.first_time_visits.to_h['countries'].to_a %>
  <% first_cities    = @digest.first_time_visits.to_h['cities'].to_a %>
  <% if first_countries.any? || first_cities.any? %>
    <h2>FIRST VISITS THIS MONTH</h2>
    <pre class="ascii"><%
      lines = []
      first_countries.first(2).each { |c| lines << "→ #{c}  (new country)" }
      first_cities.first(3 - first_countries.first(2).size).each { |c| lines << "→ #{c}  (new city)" }
    %><%= lines.join("\n") %></pre>
  <% end %>

  <% if @digest.year_over_year.to_h['distance_change_percent'].present? %>
    <h2>VS PREVIOUS MONTH</h2>
    <pre class="ascii">Distance  <%= ascii_trend(@digest.distance, @digest.distance / (1 + @digest.year_over_year['distance_change_percent'].to_f / 100)) %>
</pre>
  <% end %>

  <p><a href="<%= insights_url %>">View full insights &rarr;</a></p>

  <div class="footer">
    You're receiving this because monthly digest emails are on for your account.
    <a href="<%= settings_general_index_url(anchor: 'email-digests') %>">Manage email preferences</a>.
  </div>
</body>
</html>
