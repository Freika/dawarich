<%# Shared page header partial
  As layout (with actions):
    render layout: 'shared/page_header', locals: { title: 'Trips' } do
      link_to 'New trip', new_trip_path, class: 'btn btn-primary'
    end

  Without actions:
    render 'shared/page_header', title: 'Trips'
%>
<% captured = capture { yield } if block_given? %>
<div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between mb-6">
  <h1 class="text-3xl font-bold"><%= title %></h1>
  <% if captured.present? %>
    <div class="flex flex-wrap gap-2">
      <%= captured %>
    </div>
  <% end %>
</div>
