<div class="suggested-picker" data-visit-id="<%= entry[:visit_id] %>">
  <div class="text-xs font-semibold text-amber-900 mb-1">Is this right?</div>
  <%= form_with url: visit_path(entry[:visit_id]), method: :patch, local: false do |f| %>
    <% entry[:suggested_places].each_with_index do |place, idx| %>
      <label class="suggested-picker__option">
        <%= f.radio_button 'visit[place_id]', place[:id], checked: idx.zero? %>
        <span><%= place[:name] %></span>
      </label>
    <% end %>
    <div class="flex gap-1 mt-2">
      <%= f.hidden_field 'visit[status]', value: 'confirmed' %>
      <%= f.submit 'Confirm', data: { testid: 'visit-confirm' }, class: 'btn btn-xs btn-success' %>
    </div>
  <% end %>
  <%= button_to 'Decline', visit_path(entry[:visit_id], visit: { status: :declined }),
                method: :patch, class: 'btn btn-xs btn-ghost mt-1' %>
</div>
