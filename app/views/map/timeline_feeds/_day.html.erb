<% entries = Array(day[:entries]); displayed_entries = entries.first(50); suggested_count = day[:summary][:suggested_count].to_i %>
<div class="timeline-day" data-day="<%= day[:date] %>" data-bounds="<%= day_bounds_json(day) %>">
  <div class="timeline-day-header">
    <button data-testid="day-prev"
            data-action="click->timeline-feed#navigateDay"
            data-direction="prev"
            title="Previous day"
            class="btn btn-ghost btn-xs">‹</button>
    <div class="flex-1 text-center">
      <div class="font-bold"><%= day_label(day) %></div>
      <div class="text-xs text-base-content/60"><%= day_total_visits_count(day) %> visits</div>
    </div>
    <button data-testid="day-next"
            data-action="click->timeline-feed#navigateDay"
            data-direction="next"
            title="Next day"
            class="btn btn-ghost btn-xs">›</button>
  </div>

  <% if suggested_count.positive? %>
    <div class="timeline-bulk-banner">
      <span><%= suggested_count %> suggestions waiting</span>
      <%= button_to 'Confirm all',
                    bulk_update_visits_path(status: :confirmed, source_status: :suggested, date: day[:date]),
                    method: :patch,
                    data: { testid: 'bulk-confirm-day' },
                    class: 'btn btn-xs btn-success' %>
      <%= button_to 'Decline all',
                    bulk_update_visits_path(status: :declined, source_status: :suggested, date: day[:date]),
                    method: :patch,
                    class: 'btn btn-xs btn-ghost' %>
    </div>
  <% end %>

  <%= render partial: 'map/timeline_feeds/day_summary', locals: { summary: day[:summary] } %>

  <% if displayed_entries.present? %>
    <ol class="timeline-entries">
      <% displayed_entries.each do |entry| %>
        <% if entry[:type] == 'visit' %>
          <%= render partial: 'map/timeline_feeds/visit_entry', locals: { entry: entry, day: day } %>
        <% else %>
          <%= render partial: 'map/timeline_feeds/journey_entry', locals: { entry: entry } %>
        <% end %>
      <% end %>
    </ol>
    <% if entries.size > displayed_entries.size %>
      <div class="text-center py-2">
        <%# TODO: implement proper ?page= pagination on controller side %>
        <%= link_to "Show all (#{entries.size} total)",
                    map_timeline_feeds_path(start_at: day[:date], end_at: day[:date], show_all: true),
                    data: { turbo_frame: 'timeline-feed-frame' },
                    class: 'btn btn-ghost btn-xs' %>
      </div>
    <% end %>
  <% else %>
    <p class="text-center text-sm text-base-content/60 py-6">No visits tracked this day.</p>
  <% end %>
</div>
