<%
  start_time = Time.zone.parse(entry[:started_at]).strftime('%H:%M')
  duration = format_duration_short(entry[:duration])
  place_name = entry[:name].presence || 'Unknown Location'
  place = entry[:place]
  location = place ? [place[:city], place[:country]].compact.join(', ') : nil
%>
<div class="timeline-entry"
     data-action="mouseenter->timeline-feed#entryHover mouseleave->timeline-feed#entryUnhover"
     data-entry-type="visit"
     data-started-at="<%= entry[:started_at] %>"
     data-ended-at="<%= entry[:ended_at] %>"
     data-visit-name="<%= place_name %>"
     <% if place %>
       data-visit-lat="<%= place[:lat] %>"
       data-visit-lng="<%= place[:lng] %>"
     <% end %>>
  <div class="timeline-entry-time"><%= start_time %></div>
  <div class="timeline-entry-content">
    <div class="text-sm truncate" title="<%= place_name %>"><%= place_name %></div>
    <div class="text-xs text-base-content/40 mt-px">
      <%= duration %>
      <% if location.present? %>
        &middot; <%= location %>
      <% end %>
    </div>
  </div>
</div>
