<% times = visit_entry_times(entry); status = visit_entry_status(entry); all_day = visit_entry_all_day?(entry) %>
<li class="visit-row<%= ' visit-row--all-day' if all_day %>"
    data-visit-id="<%= entry[:visit_id] %>"
    data-status="<%= status %>"
    data-testid="visit-row"
    data-action="click->timeline-feed#selectVisit"
    data-started-at="<%= entry[:started_at] %>"
    data-ended-at="<%= entry[:ended_at] %>"
    <% if entry[:place] %>
      data-visit-lat="<%= entry[:place][:lat] %>"
      data-visit-lng="<%= entry[:place][:lng] %>"
    <% end %>>
  <div class="visit-row__time">
    <% if all_day %>
      <span class="text-xs">All day</span>
    <% else %>
      <div class="font-mono text-xs"><%= times[:start_label] %></div>
      <div class="font-mono text-[10px] text-base-content/50"><%= times[:end_label] %></div>
    <% end %>
  </div>

  <div class="visit-row__rail">
    <span class="visit-status-dot visit-status-dot--<%= status %>"></span>
  </div>

  <div class="visit-row__content">
    <div class="visit-row__title">
      <% if entry[:place_id] %>
        <button class="place-link font-bold"
                data-place-id="<%= entry[:place_id] %>"
                data-action="click->timeline-feed#openPlaceDrawer"
                type="button">
          <%= visit_entry_display_name(entry) %>
        </button>
      <% else %>
        <span class="font-bold"><%= visit_entry_display_name(entry) %></span>
      <% end %>
    </div>
    <div class="visit-row__meta text-xs text-base-content/60">
      <%= format_dwell_minutes(entry[:duration]) %> · <%= entry[:point_count] %> pts
      <% Array(entry[:tags]).each do |t| %>
        <span class="tag-chip" style="background-color: <%= t[:color] %>;">#<%= t[:name] %></span>
      <% end %>
    </div>

    <% if status == 'suggested' && entry[:suggested_places].present? %>
      <%= render partial: 'map/timeline_feeds/suggested_picker', locals: { entry: entry } %>
    <% end %>
  </div>

  <% if status != 'suggested' %>
    <div class="visit-row__actions">
      <% if status == 'confirmed' %>
        <%= button_to 'Decline', visit_path(entry[:visit_id], visit: { status: :declined }),
                      method: :patch,
                      data: { testid: 'visit-decline' },
                      class: 'btn btn-xs btn-ghost' %>
      <% else %>
        <%= button_to 'Restore', visit_path(entry[:visit_id], visit: { status: :confirmed }),
                      method: :patch,
                      class: 'btn btn-xs btn-ghost' %>
      <% end %>
    </div>
  <% end %>
</li>
