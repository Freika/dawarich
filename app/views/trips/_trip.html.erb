<%= link_to trip, class: "block group" do %>
  <div class="border border-base-300 rounded-xl overflow-hidden transition-all duration-200 hover:border-primary/30 hover:-translate-y-1 hover:shadow-lg"
       data-trip-id="<%= trip.id %>" id="trip-<%= trip.id %>">

    <%# Map thumbnail %>
    <% if trip.path.present? %>
      <div style="width: 100%; aspect-ratio: 16/10;"
            id="map-<%= trip.id %>"
            class="bg-base-200"
            data-controller="trip-map"
            data-trip-map-trip-id-value="<%= trip.id %>"
            data-trip-map-path-value="<%= trip.path.coordinates.to_json %>"
            data-trip-map-api-key-value="<%= current_user.api_key %>"
            data-trip-map-user-settings-value="<%= current_user.safe_settings.settings.to_json %>"
            data-trip-map-timezone-value="<%= trip.user.timezone %>">
      </div>
    <% elsif trip.distance.present? %>
      <div style="width: 100%; aspect-ratio: 16/10;" class="flex items-center justify-center bg-base-200">
        <p class="text-base-content/40 text-sm">No points found</p>
      </div>
    <% else %>
      <div style="width: 100%; aspect-ratio: 16/10;" class="flex items-center justify-center bg-base-200">
        <div class="text-center">
          <div class="loading loading-spinner loading-sm"></div>
          <p class="text-base-content/40 text-xs mt-1">Calculating...</p>
        </div>
      </div>
    <% end %>

    <%# Card body %>
    <div class="px-4 py-3">
      <h3 class="font-semibold text-base group-hover:text-primary transition-colors truncate"><%= trip.name %></h3>
      <p class="text-xs text-base-content/50 mt-0.5">
        <%= human_date(trip.started_at) %> &ndash; <%= human_date(trip.ended_at) %>
      </p>

      <div class="flex items-center justify-between mt-3">
        <span class="text-sm font-medium tabular-nums">
          <%= trip.distance_in_unit(current_user.safe_settings.distance_unit).round %> <%= current_user.safe_settings.distance_unit %>
        </span>
        <div class="flex items-center gap-2">
          <% if trip.visited_countries.any? %>
            <span class="text-xs text-base-content/50">
              <%= trip.visited_countries.count %> <%= 'country'.pluralize(trip.visited_countries.count) %>
            </span>
          <% end %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-primary/10 text-primary">
            <%= pluralize(((trip.ended_at - trip.started_at) / 1.day).ceil, 'day') %>
          </span>
        </div>
      </div>
    </div>
  </div>
<% end %>
