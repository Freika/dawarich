<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="border border-base-300 rounded-xl px-4 py-3 text-center">
    <div class="text-xs text-base-content/50 uppercase tracking-wider">Distance</div>
    <div class="text-xl font-bold tabular-nums mt-0.5"><%= trip.distance_in_unit(distance_unit).round %> <%= distance_unit %></div>
  </div>
  <div class="border border-base-300 rounded-xl px-4 py-3 text-center">
    <div class="text-xs text-base-content/50 uppercase tracking-wider">Duration</div>
    <div class="text-xl font-bold mt-0.5"><%= trip_duration(trip) %></div>
  </div>
  <div class="border border-base-300 rounded-xl px-4 py-3 text-center cursor-pointer hover:bg-base-200/50 transition-colors"
       onclick="countries_modal_<%= trip.id %>.showModal()">
    <div class="text-xs text-base-content/50 uppercase tracking-wider">Countries</div>
    <div class="text-xl font-bold mt-0.5">
      <% if trip.visited_countries.any? %>
        <%= trip.visited_countries.count %>
      <% else %>
        <span class="text-base-content/40">&mdash;</span>
      <% end %>
    </div>
  </div>
</div>

<dialog id="countries_modal_<%= trip.id %>" class="modal">
  <div class="modal-box">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">
        <%= icon 'x', class: 'w-4 h-4' %>
      </button>
    </form>
    <h3 class="font-bold text-lg mb-4">Visited Countries</h3>
    <% if trip.visited_countries.any? %>
      <div class="space-y-2">
        <% trip.visited_countries.sort.each do |country| %>
          <div class="px-3 py-2 bg-base-200 rounded-lg text-sm"><%= country %></div>
        <% end %>
      </div>
    <% else %>
      <p class="text-base-content/50">No countries data available yet.</p>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
