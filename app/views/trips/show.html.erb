<% content_for :title, @trip.name %>

<%= turbo_stream_from "trip_#{@trip.id}" %>

<div class="w-full my-5">
  <%# Header %>
  <%= render layout: 'shared/page_header', locals: { title: @trip.name } do %>
    <div class="flex items-center gap-2">
      <%= link_to edit_trip_path(@trip), class: "btn btn-outline btn-sm" do %>
        <%= icon 'square-pen', class: 'w-4 h-4' %> Edit
      <% end %>
      <%= link_to trip_path(@trip),
          data: { turbo_confirm: "Are you sure?", turbo_method: :delete },
          class: "btn btn-ghost btn-sm text-error hover:bg-error/10" do %>
        <%= icon 'trash-2', class: 'w-4 h-4' %> Delete
      <% end %>
      <%= link_to trips_path, class: "btn btn-ghost btn-sm" do %>
        <%= icon 'arrow-left', class: 'w-4 h-4' %> Back
      <% end %>
    </div>
  <% end %>

  <p class="text-sm text-base-content/50 -mt-4 mb-6">
    <%= human_date(@trip.started_at) %> &ndash; <%= human_date(@trip.ended_at) %>
  </p>

  <%# Stats row %>
  <%= render "trips/countries", trip: @trip, current_user: current_user, distance_unit: current_user.safe_settings.distance_unit %>

  <%# Map + Details %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%# Map %>
    <div class="border border-base-300 rounded-xl overflow-hidden" id="trip_path">
      <%= render "trips/path", trip: @trip, current_user: current_user %>
    </div>

    <%# Details %>
    <div>
      <% if @trip.notes.body.present? %>
        <div class="border border-base-300 rounded-xl p-5 mb-6 prose prose-sm max-w-none">
          <%= @trip.notes.body %>
        </div>
      <% end %>

      <% if @photo_previews.any? %>
        <div class="grid grid-cols-3 gap-3 mb-6">
          <% @photo_previews.each do |photo| %>
            <div class="aspect-square overflow-hidden rounded-xl transition-transform duration-200 hover:scale-105 hover:shadow-lg">
              <img src="<%= photo[:url] %>" loading="lazy" class="h-full w-full object-cover">
            </div>
          <% end %>
        </div>

        <% if @photo_sources.any? %>
          <div class="flex flex-wrap gap-2 mb-6">
            <% @photo_sources.each do |source| %>
              <%= link_to photo_search_url(source, current_user.settings, @trip.started_at, @trip.ended_at), class: "btn btn-outline btn-sm", target: '_blank' do %>
                <%= icon 'camera', class: 'w-4 h-4' %> More on <%= source %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
