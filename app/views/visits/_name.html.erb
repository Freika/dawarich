<%
  if local_assigns[:visit]
    resolved_id = visit.id
    resolved_name = visit.default_name
    resolved_suggested = visit.suggested?
  else
    resolved_id = local_assigns[:visit_id]
    resolved_name = local_assigns[:name]
    resolved_suggested = local_assigns.fetch(:suggested, false)
  end
%>
<%= turbo_frame_tag "visit_name_#{resolved_id}" do %>
  <span class="<%= 'underline decoration-dotted' if resolved_suggested %>"
        data-controller="visit-name"
        data-visit-name-target="wrapper">
    <%# Visit Name Display %>
    <span
      data-visit-name="<%= resolved_id %>"
      data-visit-name-target="name"
      data-action="click->visit-name#edit"
      data-testid="visit-rename-trigger"
      data-tip="Click to rename"
      class="hover:cursor-pointer tooltip">
      <% if resolved_name.present? %>
        <%= resolved_name %>
      <% else %>
        <span class="text-base-content/40 italic">Unnamed visit</span>
      <% end %>
    </span>

    <%# Inline rename form — shown by visit-name Stimulus controller %>
    <%= form_with(url: visit_path(resolved_id), scope: :visit, method: :patch,
                  class: "hidden inline",
                  data: { visit_name_target: "form" }) do |f| %>
      <%= f.text_field :name, value: resolved_name,
          data: {
            visit_name_target: "input",
            testid: "visit-rename-input",
            action: "blur->visit-name#save keydown->visit-name#handleEnter"
          },
          class: "input input-xs input-bordered w-48" %>
    <% end %>
  </span>
<% end %>
