DATABASE_HOST=localhost
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=dawarich_test
DATABASE_PORT=5432
REDIS_URL=redis://localhost:6379

# Subscription / trial JWT — Subscription::EncodeJwtToken /
# DecodeJwtToken / User#generate_subscription_token all fail-loud via
# `ENV.fetch('JWT_SECRET_KEY')`. Specs use the same value (the
# fail-loud-on-misconfiguration spec stubs ENV directly).
# Mobile auth (Api::V1::Auth) reuses JWT_SECRET_KEY for OTP challenge and
# account-link tokens; purpose claims keep them disjoint.
JWT_SECRET_KEY=test_secret
AUTH_JWT_SECRET_KEY=test_secret

# Mobile auth OAuth verifiers (test-only)
APPLE_BUNDLE_ID=app.dawarich.test
GOOGLE_IOS_CLIENT_ID=test-ios-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=test-android-client-id.apps.googleusercontent.com
