# Subscription / trial JWT — Subscription::EncodeJwtToken /
# DecodeJwtToken / User#generate_subscription_token all fail-loud via
# `ENV.fetch('JWT_SECRET_KEY')`. Specs use the same value (the
# fail-loud-on-misconfiguration spec stubs ENV directly).
JWT_SECRET_KEY=test_secret
AUTH_JWT_SECRET_KEY=test_secret
