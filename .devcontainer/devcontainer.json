{
  "name": "Dawarich Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dawarich_app",
  "workspaceFolder": "/var/app",
  "overrideCommand": true,
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens"
      ],
      "settings": {
        "rubyLsp.rubyVersionManager": { "identifier": "none" },
        "rubyLsp.formatter": "rubocop",
        "rubyLsp.bundleGemfile": "",
        "[ruby]": {
          "editor.defaultFormatter": "Shopify.ruby-lsp",
          "editor.formatOnSave": true
        }
      }
    }
  },
  "forwardPorts": [3000, 5432, 6379], // Web, DB, and Redis
  "onCreateCommand": "bundle install && yarn install --ignore-engines",
  "postCreateCommand": "bundle exec rails db:prepare",
  "postStartCommand": "./bin/dev"
}